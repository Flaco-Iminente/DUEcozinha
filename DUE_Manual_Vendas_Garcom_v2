function renderGlossario(){
  var container = document.getElementById('glosContainer');
  container.innerHTML = '';
  var letters = {};
  GLOSSARIO.forEach(function(g){
    var l = g.t[0].toUpperCase();
    if(!letters[l]) letters[l]=[];
    letters[l].push(g);
  });
  Object.keys(letters).sort().forEach(function(l){
    var lDiv = document.createElement('div');
    lDiv.innerHTML = '<div class="glos-letter">'+l+'</div>';
    letters[l].forEach(function(g){
      var item = document.createElement('div');
      item.className = 'glos-item';
      item.dataset.term = (g.t+' '+g.d).toLowerCase();
      item.innerHTML = '<div class="glos-term">'+g.t+'</div><div class="glos-def">'+g.d+'</div>';
      lDiv.appendChild(item);
    });
    container.appendChild(lDiv);
  });
}

function searchGlos(val){
  var v = val.toLowerCase();
  document.querySelectorAll('.glos-item').forEach(function(item){
    item.classList.toggle('hidden', v && !item.dataset.term.includes(v));
  });
  document.querySelectorAll('.glos-letter').forEach(function(lh){
    var next = lh.nextSibling;
    var anyVisible = false;
    while(next && !next.classList.contains('glos-letter')){
      if(next.classList && !next.classList.contains('hidden')) anyVisible = true;
      next = next.nextSibling;
    }
    lh.style.display = anyVisible ? '' : 'none';
  });
}

