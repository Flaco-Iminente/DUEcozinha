function renderMatrix(data){
  var tbody = document.getElementById('matrixBody');
  tbody.innerHTML = '';
  data.forEach(function(d){
    var tr = document.createElement('tr');
    tr.dataset.g=d.G; tr.dataset.l=d.L; tr.dataset.c=d.C; tr.dataset.m=d.M;
    tr.dataset.p=d.P; tr.dataset.o=d.O; tr.dataset.k=d.K; tr.dataset.a=d.A; tr.dataset.sf=d.SF;
    function dot(v,cls){return v?'<td class="center"><span class="dot-yes"></span></td>':'<td></td>';}
    function dotSF(v){return v?'<td class="center"><span class="dot-sf"></span></td>':'<td></td>';}
    tr.innerHTML =
      '<td><div class="dish-name">'+d.nome+'</div><div class="dish-cat">'+d.cat+' · R$'+d.pr+'</div></td>'+
      dot(d.G)+dot(d.L)+dot(d.C)+dot(d.M)+dot(d.P)+dot(d.O)+dot(d.K)+dot(d.A)+dotSF(d.SF);
    tbody.appendChild(tr);
  });
}

function filterAl(type,btn){
  activeFilter = type;
  document.querySelectorAll('.fbtn').forEach(function(b){b.classList.remove('active')});
  btn.classList.add('active');
  var keyMap = {gluten:'g',lactose:'l',crustaceo:'c',molusco:'m',peixe:'p',ovo:'o',castanha:'k',amendoim:'a',sf:'sf'};
  var rows = document.querySelectorAll('#matrixBody tr');
  rows.forEach(function(row){
    if(type==='all'){row.style.display='';return;}
    var key = keyMap[type];
    if(!key){row.style.display='';return;}
    row.style.display = (row.dataset[key]==='1') ? '' : 'none';
  });
}

